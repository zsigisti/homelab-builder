# =============================================================================
# HLBuilder — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values before deploying/running.
# =============================================================================

# ── General & Timezone ───────────────────────────────────────────────────────
TZ=Europe/Berlin

# ── Backend Configuration ────────────────────────────────────────────────────
SERVER_PORT=8080

# Database Connection (used within internal Docker network or locally)
DB_HOST=postgres
DB_PORT=5432
DB_USER=homelab
DB_PASSWORD=your_secure_db_password_here
DB_NAME=homelab_builder
DB_SSLMODE=disable
DB_TYPE=postgres

# Authentication Secrets
JWT_SECRET=your_jwt_signing_secret_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# IPAM Microservice Address (internal Docker container name)
IPAM_URL=http://hlbipam:8081

# ── Frontend Configuration (baked into Vite build) ──────────────────────────
# In production, set this to your public domain (e.g., https://hlbldr.com).
# In local development, set this to http://localhost:8080 (the backend host).
VITE_API_URL=https://hlbldr.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# ── Docker Compose Specifics ─────────────────────────────────────────────────
# Path on host to store persistent database data.
# Can be a relative path like ./postgres-data, or leave empty/remove to use Docker named volumes.
DB_PATH=./postgres-data

# Host ports to expose
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Fallback address used if VITE_API_URL is not set
IP_ADRESS=localhost
